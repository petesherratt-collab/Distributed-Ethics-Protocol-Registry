# -----------------------------------------------------------------------
# Distributed Ethics — Protocol Registry CLI configuration
# Copy this file to .env and fill in your values. Never commit .env.
# -----------------------------------------------------------------------

# JSON-RPC endpoint.
# Sepolia public endpoint shown — swap for Infura/Alchemy for reliability.
# Mainnet: https://mainnet.infura.io/v3/YOUR_KEY
REGISTRY_RPC=https://rpc.sepolia.org

# Address of the deployed ProtocolRegistry contract.
# Run `python ethics_verify.py deploy` to get this, or deploy via Remix:
#   https://remix.ethereum.org  →  paste ProtocolRegistry.sol  →  Deploy
REGISTRY_CONTRACT=0x

# Private key of the issuing-authority wallet.
# Required only for `register` and `deploy` commands.
# The address derived from this key becomes the on-chain issuing authority.
# Protect this value — it authorises new protocol registrations.
REGISTRY_PRIVATE_KEY=0x
